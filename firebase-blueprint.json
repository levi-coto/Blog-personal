{
  "entities": {
    "post": {
      "title": "Post",
      "description": "A blog post entry",
      "type": "object",
      "properties": {
        "slug": { "type": "string", "description": "Unique URL slug" },
        "date": { "type": "string", "description": "Publication date in yyyy.MM.dd format" },
        "es": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "excerpt": { "type": "string" },
            "content": { "type": "string" }
          }
        },
        "en": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "excerpt": { "type": "string" },
            "content": { "type": "string" }
          }
        }
      },
      "required": ["slug", "date", "es", "en"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "post",
      "description": "Collection of blog posts"
    }
  }
}
