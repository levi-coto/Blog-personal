rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: posts
    // Document ID: auto-generated
    // Fields:
    //   - slug: string (required)
    //   - date: string (required, yyyy.MM.dd)
    //   - es: map { title, excerpt, content }
    //   - en: map { title, excerpt, content }
    //
    // ===============================================================

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "hello@levicoto.com" && request.auth.token.email_verified == true);
    }

    // Posts: Publicly readable, only admin can write
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
